#!/bin/bash

staged_sh=$(git diff --cached --name-only --diff-filter=ACM | grep '\.sh$')

[[ -z "$staged_sh" ]] && exit 0

if command -v shfmt &> /dev/null; then
  # -d (diff) checks formatting without modifying files. -w would rewrite and
  # require a follow-up `git add`, which breaks `git add -p` interactive staging.
  failed=false
  while IFS= read -r f; do
    if ! shfmt -i 2 -sr -d "$f"; then
      failed=true
    fi
  done <<< "$staged_sh"
  if [[ "$failed" == true ]]; then
    echo "✗ shfmt: run 'shfmt -i 2 -sr -w <file>' to fix formatting"
    exit 1
  fi
fi

if command -v shellcheck &> /dev/null; then
  # Loop instead of xargs to handle filenames with spaces correctly.
  failed=false
  while IFS= read -r f; do
    if ! shellcheck "$f"; then
      failed=true
    fi
  done <<< "$staged_sh"
  if [[ "$failed" == true ]]; then
    echo "✗ shellcheck failed"
    exit 1
  fi
fi
