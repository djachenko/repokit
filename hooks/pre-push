#!/bin/bash

USER_EMAIL=$(git config user.email 2>/dev/null || true)
GLOBAL_ALLOWED=$(git config --global --get-all repokit.allowedEmail 2>/dev/null || true)
LOCAL_ALLOWED=$(git config --local --get-all repokit.allowedEmail 2>/dev/null || true)

ALL_ALLOWED="$GLOBAL_ALLOWED"
if [[ -n "$LOCAL_ALLOWED" ]]; then
  ALL_ALLOWED="${ALL_ALLOWED:+$ALL_ALLOWED$'\n'}$LOCAL_ALLOWED"
fi
if [[ -n "$USER_EMAIL" ]] && ! echo "$ALL_ALLOWED" | grep -qxF "$USER_EMAIL"; then
  ALL_ALLOWED="${ALL_ALLOWED:+$ALL_ALLOWED$'\n'}$USER_EMAIL"
fi

if [[ -z "$ALL_ALLOWED" ]]; then
  echo "✗ git user.email is not set and repokit.allowedEmail is empty"
  exit 1
fi

while IFS=' ' read -r local_ref local_sha remote_ref remote_sha; do
  # branch deletion — nothing to check
  [[ "$local_sha" == "0000000000000000000000000000000000000000" ]] && continue

  if [[ "$remote_sha" == "0000000000000000000000000000000000000000" ]]; then
    # new branch: commits reachable from local_sha but not yet on any remote
    range="$local_sha --not --remotes"
  else
    range="$remote_sha..$local_sha"
  fi

  [[ -z "$(git rev-list $range 2>/dev/null)" ]] && continue

  bad=""
  while IFS= read -r line; do
    [[ -z "$line" ]] && continue
    email=$(awk '{print $2}' <<< "$line")
    if ! echo "$ALL_ALLOWED" | grep -qxF "$email"; then
      bad+="$line"$'\n'
    fi
  done < <(git log --format="%h %ae %s" $range)
  bad=${bad%$'\n'}

  if [[ -n "$bad" ]]; then
    if [[ "$(git config repokit.allowForeignAuthors)" == "true" ]]; then
      continue
    fi

    echo "⚠ Commits with unexpected author email:"
    while IFS= read -r line; do
      [[ -z "$line" ]] && continue
      hash=$(awk '{print $1}' <<< "$line")
      email=$(awk '{print $2}' <<< "$line")
      subject=$(awk '{$1=$2=""; print substr($0,3)}' <<< "$line")
      echo "  $hash <$email> $subject"
    done <<< "$bad"
    echo ""
    printf "[1] Allow once  [2] Allow always  [3] Deny (default): " > /dev/tty
    read -r answer < /dev/tty
    case "$answer" in
      1) ;;
      2)
        while IFS= read -r line; do
          [[ -z "$line" ]] && continue
          email=$(awk '{print $2}' <<< "$line")
          if ! git config --local --get-all repokit.allowedEmail 2>/dev/null | grep -qxF "$email"; then
            git config --local --add repokit.allowedEmail "$email"
            echo "→ Added $email to .git/config (repokit.allowedEmail)"
          fi
        done <<< "$bad"
        ;;
      *)
        echo "Aborted."
        exit 1
        ;;
    esac
  fi
done
