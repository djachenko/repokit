#!/bin/bash

EXPECTED=$(git config user.email)

if [[ -z "$EXPECTED" ]]; then
  echo "✗ git user.email is not set"
  exit 1
fi

while IFS=' ' read -r local_ref local_sha remote_ref remote_sha; do
  if [[ "$remote_sha" == "0000000000000000000000000000000000000000" ]]; then
    range=$(git rev-list --not --remotes "$local_sha" 2>/dev/null)
  else
    range="$remote_sha..$local_sha"
  fi

  [[ -z "$range" ]] && continue

  bad=$(git log --format="%h %ae %s" $range | awk -v e="$EXPECTED" '$2 != e')

  if [[ -n "$bad" ]]; then
    if [[ "$(git config repokit.allowForeignAuthors)" == "true" ]]; then
      continue
    fi

    echo "⚠ Commits with unexpected author email (expected: $EXPECTED):"
    while IFS= read -r line; do
      echo "  $line"
    done <<< "$bad"
    echo ""
    printf "Push anyway? [y/N] " > /dev/tty
    read -r answer < /dev/tty
    if [[ "$answer" != "y" ]]; then
      echo "Aborted. To skip this check: git config repokit.allowForeignAuthors true"
      exit 1
    fi
  fi
done
