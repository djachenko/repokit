#!/bin/bash

# Exit immediately if any command fails (equivalent to raising on first error).
set -e

# Absolute path to the directory containing this script, regardless of where it
# was called from. ${BASH_SOURCE[0]} is the script's own path (unlike $0, which
# can be the caller when the script is sourced). dirname strips the filename,
# then cd + pwd resolves any relative or symlinked path to an absolute one.
SCRIPT_DIR=$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)

# ── Parse .repokit state before any flags so --language can override ──────────

LANGUAGE=""
FORCE_WORKFLOWS=false
FORCE_PYPROJECT=false
# ls outputs a newline-separated list of directory entries — used as the set of
# valid language names.
AVAILABLE_LANGUAGES=$(ls "$SCRIPT_DIR/languages/")

# .repokit exists after the first run; its presence means this is an update.
IS_FIRST_SETUP=true
if [[ -f .repokit ]]; then
  # grep '^language=' finds the line starting with "language=",
  # cut -d= -f2 splits on "=" and takes the second field (the value).
  LANGUAGE=$(grep '^language=' .repokit | cut -d= -f2)
  IS_FIRST_SETUP=false
fi

# ── CLI flags ─────────────────────────────────────────────────────────────────

# $# = number of remaining positional arguments. Loop until all args consumed.
while [[ $# -gt 0 ]]; do
  case "$1" in
    --version|-v)
      # 2>/dev/null suppresses "No such file" if VERSION is missing; || provides fallback.
      VERSION=$(cat "$SCRIPT_DIR/VERSION" 2>/dev/null || echo "unknown")
      echo "repokit $VERSION"
      exit 0
      ;;
    --help|-h)
      # tr '\n' ' ' converts newline-separated list to space-separated (for display).
      echo "Usage: repokit [--language <name>] [--force-workflows] [--force-pyproject]"
      echo ""
      echo "Initializes a GitHub repository in the current directory."
      echo ""
      echo "  1. Create a folder:  mkdir my-repo"
      echo "  2. Enter it:         cd my-repo"
      echo "  3. Run:              repokit --language python"
      echo ""
      echo "On subsequent runs --language is optional if .repokit exists locally."
      echo ""
      echo "Options:"
      echo "  --language <name>    Language profile to use."
      echo "                       Available: $(echo "$AVAILABLE_LANGUAGES" | tr '\n' ' ')"
      echo "  --force-workflows    Overwrite workflows even if not repokit-managed;"
      echo "                       commits under repokit authorship."
      echo "  --force-pyproject    Overwrite pyproject.toml even if it already exists;"
      echo "                       commits under repokit authorship."
      echo ""
      echo "Repo name is taken from the current directory name."
      echo "GitHub owner is taken from 'gh auth'."
      echo ""
      echo "Requirements:"
      echo "  git  — https://git-scm.com"
      echo "  gh   — https://cli.github.com (must be authenticated)"
      exit 0
      ;;
    --language)
      LANGUAGE="$2"
      shift 2  # consume both the flag and its value from the argument list
      ;;
    --force-workflows)
      FORCE_WORKFLOWS=true
      shift    # consume just the flag
      ;;
    --force-pyproject)
      FORCE_PYPROJECT=true
      shift
      ;;
    *)
      echo "Unknown option: $1"
      exit 1
      ;;
  esac
done

# -z = "zero length" — true if the string is empty.
if [[ -z "$LANGUAGE" ]]; then
  echo "Error: --language is required. Available: $(echo "$AVAILABLE_LANGUAGES" | tr '\n' ' ')"
  exit 1
fi

# grep -qx: -q = quiet (no output), -x = exact whole-line match.
# ! inverts the exit code — true if $LANGUAGE is NOT in the list.
if ! echo "$AVAILABLE_LANGUAGES" | grep -qx "$LANGUAGE"; then
  echo "Error: unknown language '$LANGUAGE'. Available: $(echo "$AVAILABLE_LANGUAGES" | tr '\n' ' ')"
  exit 1
fi

# ── Shared exports ────────────────────────────────────────────────────────────
#
# export makes variables visible to child processes (the init/*.sh subshells).
# Without export, a variable only exists in the current shell.

export SCRIPT_DIR
export LANGUAGE
export REPO
# basename = last component of a path: /home/user/my-repo → my-repo.
REPO=$(basename "$PWD")
export REPOKIT_AUTHOR="repokit <repokit@djachenko>"

# run_quiet <cmd...> → runs silently; prints output only on failure.
# Lets the UI stay clean on success while still surfacing errors.
run_quiet() {
  local out status
  # "$@" expands to all arguments as separate words (preserving spaces in args).
  # 2>&1 merges stderr into stdout so both are captured together.
  out=$("$@" 2>&1)
  # $? = exit code of the last command (must be read immediately before anything else overwrites it).
  status=$?
  if [[ $status -ne 0 ]]; then
    # >&2 sends output to stderr so it doesn't pollute stdout of callers.
    printf '%s\n' "$out" >&2
  fi
  return $status
}
# export -f makes the function available in child bash processes (subshells
# spawned for the init scripts inherit it via environment).
export -f run_quiet

repokit_commit() {
  run_quiet git commit -m "chore: [repokit] $1" --author="$REPOKIT_AUTHOR"
}
export -f repokit_commit

# ask_yn "Question?" → returns 0 (yes) or 1 (no).
ask_yn() {
  # -n suppresses the trailing newline so the cursor stays on the same line.
  echo -n "$1 [y/N] "
  # -r = don't interpret backslashes; -n 1 = read exactly one character without
  # waiting for Enter.
  read -rn 1 answer
  echo  # print a newline after the single character input
  # =~ is regex match; ^[Yy]$ matches exactly one character: Y or y.
  [[ "$answer" =~ ^[Yy]$ ]]
}
export -f ask_yn

# ── Preflight: verify git, gh, auth ──────────────────────────────────────────

bash "$SCRIPT_DIR/init/01_check_tools.sh"

export OWNER
# gh api user returns JSON like {"login": "djachenko", ...}.
# --jq '.login' parses it and extracts just the login string.
OWNER=$(gh api user --jq '.login')

# ── Detect current repo state ─────────────────────────────────────────────────

HAS_GIT=false
# git rev-parse --git-dir prints the path to .git and exits 0 inside a repo,
# exits non-zero outside one. &>/dev/null discards both stdout and stderr.
# && runs the right side only if the left side succeeds (exit 0).
git rev-parse --git-dir &> /dev/null && HAS_GIT=true

HAS_REMOTE=false
# gh repo view exits 0 if the repo exists on GitHub, non-zero otherwise.
gh repo view "$OWNER/$REPO" &> /dev/null && HAS_REMOTE=true

if [[ "$HAS_GIT" == false && "$HAS_REMOTE" == true ]]; then
  echo "Error: GitHub repo '$OWNER/$REPO' already exists but no local git. Clone it first."
  exit 1
fi

# ── Git init (if needed) ──────────────────────────────────────────────────────

if [[ "$HAS_GIT" == false ]]; then
  # || exit 0: if ask_yn returns non-zero (user said N), exit cleanly.
  ask_yn "Init git in $(pwd)?" || exit 0
  bash "$SCRIPT_DIR/init/02_git_init.sh"
fi

# Switch HTTPS remote to SSH if needed.
# gh repo create sets up HTTPS; we want SSH so git operations don't prompt for credentials.
if [[ "$HAS_GIT" == true ]]; then
  # 2>/dev/null: suppress error if there's no remote named "origin".
  # || true: if the command fails (no origin), don't abort — just leave remote_url empty.
  remote_url=$(git remote get-url origin 2>/dev/null || true)
  if [[ "$remote_url" == https://github.com/* ]]; then
    # ${var#prefix} strips the given prefix from the variable value.
    # "https://github.com/owner/repo.git" → "owner/repo.git"
    ssh_url="git@github.com:${remote_url#https://github.com/}"
    echo "→ Switching remote from HTTPS to SSH..."
    run_quiet git remote set-url origin "$ssh_url"
  fi
fi

# ── Create GitHub repo + initial push (if needed) ────────────────────────────

if [[ "$HAS_REMOTE" == false ]]; then
  ask_yn "Create GitHub repo '$OWNER/$REPO'?" || exit 0
  bash "$SCRIPT_DIR/init/03_create_repo.sh"

  # Check if repo already has commits (e.g. user ran git init + committed manually).
  # --oneline gives one line per commit; grep -q . matches any non-empty output.
  if git log --oneline 2> /dev/null | grep -q .; then
    echo "→ Pushing existing history..."
    run_quiet git push -u origin master
  else
    bash "$SCRIPT_DIR/init/04_initial_commit.sh"
  fi
fi

# ── Setup branch: create or rebase onto latest base ──────────────────────────
#
# All repokit changes land on chore/repokit-setup and go through a PR.
# On re-runs we rebase the branch onto the current base instead of recreating
# it, so any manual fixes on the branch are preserved.

BRANCH="chore/repokit-setup"
# --abbrev-ref HEAD = human-readable branch name (e.g. "main") instead of SHA.
CURRENT_BRANCH=$(git rev-parse --abbrev-ref HEAD)

if [[ "$CURRENT_BRANCH" == "$BRANCH" ]]; then
  # Already on the setup branch (re-run after partial failure). Read base from .repokit.
  BASE_BRANCH=$(grep '^base_branch=' .repokit 2>/dev/null | cut -d= -f2)
  # ${var:-default}: if BASE_BRANCH is empty or unset, use "master".
  BASE_BRANCH=${BASE_BRANCH:-master}
else
  # Normal case: current branch is the base we'll branch off from.
  BASE_BRANCH="$CURRENT_BRANCH"
fi

run_quiet git fetch origin "$BASE_BRANCH"
BRANCH_ON_REMOTE=false
# ls-remote --exit-code exits 2 (non-zero) if the ref doesn't exist on origin.
# --heads limits the search to branches only (refs/heads/*).
if git ls-remote --exit-code --heads origin "$BRANCH" &> /dev/null; then
  BRANCH_ON_REMOTE=true
  run_quiet git fetch origin "$BRANCH"
fi

LOCAL_BRANCH_EXISTS=false
# rev-parse --verify checks if the name resolves to a valid git object.
git rev-parse --verify "$BRANCH" &>/dev/null && LOCAL_BRANCH_EXISTS=true

if $LOCAL_BRANCH_EXISTS || $BRANCH_ON_REMOTE; then
  echo "→ Updating branch $BRANCH from origin/$BASE_BRANCH..."
  if $LOCAL_BRANCH_EXISTS; then
    run_quiet git checkout "$BRANCH"
  else
    # -B: create the branch if it doesn't exist locally, or reset it if it does.
    run_quiet git checkout -B "$BRANCH" "origin/$BRANCH"
  fi
  if ! run_quiet git rebase "origin/$BASE_BRANCH"; then
    # Clean up the failed rebase state before exiting.
    git rebase --abort 2>/dev/null || true
    echo "Error: could not rebase $BRANCH onto origin/$BASE_BRANCH — resolve manually."
    exit 1
  fi
else
  echo "→ Creating branch $BRANCH from origin/$BASE_BRANCH..."
  run_quiet git checkout -B "$BRANCH" "origin/$BASE_BRANCH"
fi

# ── Write .repokit marker + update .gitignore ────────────────────────────────

# printf with format string: %s = string, \n = newline.
# > overwrites the file (vs >> which appends).
printf 'language=%s\nbase_branch=%s\n' "$LANGUAGE" "$BASE_BRANCH" > .repokit

# grep -qxF: -F = fixed string (dot is literal, not regex), -x = whole-line match.
# 2>/dev/null: suppress error if .gitignore doesn't exist yet.
if ! grep -qxF '.repokit' .gitignore 2>/dev/null; then
  # -s = file exists and is non-empty.
  # tail -c1 = last byte of the file; -n = string is non-empty.
  # Together: file has content AND doesn't end with a newline — add one before appending.
  if [[ -s .gitignore && -n "$(tail -c1 .gitignore)" ]]; then
    echo >> .gitignore  # echo with no argument prints just a newline
  fi
  echo '.repokit' >> .gitignore
fi
git add .gitignore
# --cached = look at staged changes only (index vs HEAD, not working tree).
# --quiet = no output; exit code 0 = nothing staged, 1 = something staged.
if ! git diff --cached --quiet; then
  repokit_commit "add .repokit to .gitignore"
fi

# ── Run language setup + shared steps ────────────────────────────────────────
#
# Putting VAR=value before a command sets it as an environment variable for that
# command only — it doesn't persist in the current shell after the command exits.

REPOKIT_FORCE=$FORCE_WORKFLOWS bash "$SCRIPT_DIR/init/05_workflows.sh"
REPOKIT_FORCE=$FORCE_PYPROJECT bash "$SCRIPT_DIR/languages/$LANGUAGE/language_setup.sh"
bash "$SCRIPT_DIR/init/06_ruleset.sh"

# ── Push setup branch + open PR ──────────────────────────────────────────────

# "A..B" lists commits reachable from B but not from A — i.e. new commits on BRANCH
# since it diverged from origin/BASE_BRANCH. If empty, nothing to push.
if git log "origin/$BASE_BRANCH..$BRANCH" --oneline 2>/dev/null | grep -q .; then
  echo "→ Pushing $BRANCH..."
  if $BRANCH_ON_REMOTE; then
    echo "  force-pushing (rebased onto origin/$BASE_BRANCH)..."
    # --force-with-lease: force push only if the remote branch hasn't changed since
    # our last fetch. Safer than --force; fails if someone else pushed in the meantime.
    if ! run_quiet git push --force-with-lease -u origin "$BRANCH"; then
      echo "Error: could not push $BRANCH — origin has changes repokit didn't expect (pushed manually, or changed since the last fetch)."
      echo "Resolve manually, e.g.: git push --force origin $BRANCH"
      exit 1
    fi
  elif ! run_quiet git push -u origin "$BRANCH"; then
    echo "Error: could not push $BRANCH."
    exit 1
  fi
  # 2>/dev/null || true: suppress error if a PR already exists for this branch.
  gh pr create \
    --title "chore: [repokit] setup" \
    --body "Automated repository setup by repokit." \
    --base "$BASE_BRANCH" 2>/dev/null || true

  # Instructions describe one-time manual setup (secrets, trusted publishers).
  # Only show on first run; updates don't require repeating them.
  if [[ "$IS_FIRST_SETUP" == true ]]; then
    bash "$SCRIPT_DIR/languages/$LANGUAGE/instructions.sh"
  fi

  echo ""
  echo "✓ Done: https://github.com/$OWNER/$REPO"
else
  echo ""
  echo "✓ Already up to date"
fi

# base_branch was written to .repokit at the start of this run so that
# 06_ruleset.sh and subshells can read it. Remove it afterwards — it's
# derived from the current branch and shouldn't persist across runs.
# sed -i '': edit file in-place (-i) with no backup suffix (BSD/macOS sed requires '').
# /^base_branch=/d: delete lines that start with "base_branch=".
sed -i '' '/^base_branch=/d' .repokit
