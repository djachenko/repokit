#!/bin/bash

set -e

SCRIPT_DIR=$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)

LANGUAGE=""
FORCE_WORKFLOWS=false
FORCE_PYPROJECT=false
AVAILABLE_LANGUAGES=$(ls "$SCRIPT_DIR/languages/")

if [[ -f .repokit ]]; then
  LANGUAGE=$(grep '^language=' .repokit | cut -d= -f2)
fi

while [[ $# -gt 0 ]]; do
  case "$1" in
    --help|-h)
      echo "Usage: repokit [--language <name>] [--force-workflows] [--force-pyproject]"
      echo ""
      echo "Initializes a GitHub repository in the current directory."
      echo ""
      echo "  1. Create a folder:  mkdir my-repo"
      echo "  2. Enter it:         cd my-repo"
      echo "  3. Run:              repokit --language python"
      echo ""
      echo "On subsequent runs --language is optional if .repokit exists locally."
      echo ""
      echo "Options:"
      echo "  --language <name>    Language profile to use."
      echo "                       Available: $(echo "$AVAILABLE_LANGUAGES" | tr '\n' ' ')"
      echo "  --force-workflows    Overwrite workflows even if not repokit-managed;"
      echo "                       commits under repokit authorship."
      echo "  --force-pyproject    Overwrite pyproject.toml even if it already exists;"
      echo "                       commits under repokit authorship."
      echo ""
      echo "Repo name is taken from the current directory name."
      echo "GitHub owner is taken from 'gh auth'."
      echo ""
      echo "Requirements:"
      echo "  git  — https://git-scm.com"
      echo "  gh   — https://cli.github.com (must be authenticated)"
      exit 0
      ;;
    --language)
      LANGUAGE="$2"
      shift 2
      ;;
    --force-workflows)
      FORCE_WORKFLOWS=true
      shift
      ;;
    --force-pyproject)
      FORCE_PYPROJECT=true
      shift
      ;;
    *)
      echo "Unknown option: $1"
      exit 1
      ;;
  esac
done

if [[ -z "$LANGUAGE" ]]; then
  echo "Error: --language is required. Available: $(echo "$AVAILABLE_LANGUAGES" | tr '\n' ' ')"
  exit 1
fi

if ! echo "$AVAILABLE_LANGUAGES" | grep -qx "$LANGUAGE"; then
  echo "Error: unknown language '$LANGUAGE'. Available: $(echo "$AVAILABLE_LANGUAGES" | tr '\n' ' ')"
  exit 1
fi

export SCRIPT_DIR
export LANGUAGE
export REPO
REPO=$(basename "$PWD")
export REPOKIT_AUTHOR="repokit <repokit@djachenko>"

repokit_commit() {
  git commit -m "chore: [repokit] $1" --author="$REPOKIT_AUTHOR"
}
export -f repokit_commit

bash "$SCRIPT_DIR/init/preflight.sh"

export OWNER
OWNER=$(gh api user --jq '.login')

HAS_GIT=false
git rev-parse --git-dir &> /dev/null && HAS_GIT=true

HAS_REMOTE=false
gh repo view "$OWNER/$REPO" &> /dev/null && HAS_REMOTE=true

if [[ "$HAS_GIT" == false && "$HAS_REMOTE" == true ]]; then
  echo "Error: GitHub repo '$OWNER/$REPO' already exists but no local git. Clone it first."
  exit 1
fi

if [[ "$HAS_GIT" == false ]]; then
  echo "Init git in $(pwd)? [y/N]"
  read -r answer
  [[ "$answer" == "y" ]] || exit 0
  bash "$SCRIPT_DIR/init/git_init.sh"
fi

if [[ "$HAS_GIT" == true ]]; then
  remote_url=$(git remote get-url origin 2>/dev/null || true)
  if [[ "$remote_url" == https://github.com/* ]]; then
    ssh_url="git@github.com:${remote_url#https://github.com/}"
    echo "→ Switching remote from HTTPS to SSH..."
    git remote set-url origin "$ssh_url"
  fi
fi

if [[ "$HAS_REMOTE" == false ]]; then
  echo "Create GitHub repo '$OWNER/$REPO'? [y/N]"
  read -r answer
  [[ "$answer" == "y" ]] || exit 0
  bash "$SCRIPT_DIR/init/remote.sh"

  if git log --oneline 2> /dev/null | grep -q .; then
    echo "→ Pushing existing history..."
    git push -u origin master
  else
    bash "$SCRIPT_DIR/init/commit.sh"
  fi
fi

BRANCH="chore/repokit-setup"
CURRENT_BRANCH=$(git rev-parse --abbrev-ref HEAD)

if [[ "$CURRENT_BRANCH" == "$BRANCH" ]]; then
  BASE_BRANCH=$(grep '^base_branch=' .repokit 2>/dev/null | cut -d= -f2)
  BASE_BRANCH=${BASE_BRANCH:-master}
else
  BASE_BRANCH="$CURRENT_BRANCH"
  echo "→ Creating branch $BRANCH..."
  git checkout -B "$BRANCH"
fi

printf 'language=%s\nbase_branch=%s\n' "$LANGUAGE" "$BASE_BRANCH" > .repokit
grep -qxF '.repokit' .gitignore 2>/dev/null || echo '.repokit' >> .gitignore

REPOKIT_FORCE=$FORCE_WORKFLOWS bash "$SCRIPT_DIR/init/workflows.sh"
REPOKIT_FORCE=$FORCE_PYPROJECT bash "$SCRIPT_DIR/languages/$LANGUAGE/setup.sh"
bash "$SCRIPT_DIR/init/ruleset.sh"

if git log "$BASE_BRANCH".."$BRANCH" --oneline 2>/dev/null | grep -q .; then
  git push -u origin "$BRANCH"
  gh pr create \
    --title "chore: [repokit] setup" \
    --body "Automated repository setup by repokit." \
    --base "$BASE_BRANCH" && \
  sed -i '' '/^base_branch=/d' .repokit

  bash "$SCRIPT_DIR/languages/$LANGUAGE/instructions.sh"

  echo ""
  echo "✓ Done: https://github.com/$OWNER/$REPO"
else
  git checkout "$BASE_BRANCH"
  echo ""
  echo "✓ Already up to date"
fi
